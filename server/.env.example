# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://mindsync:mindsync@localhost:5432/mindsync?schema=public"

# Long random string. The app sends this in `Authorization: Bearer …`.
# Generate with e.g. `openssl rand -hex 32`.
SYNC_BEARER_TOKEN="change-me"

# HTTP port (optional, defaults to 3000)
PORT=3000

# Log level (trace|debug|info|warn|error). Defaults to info.
LOG_LEVEL=info
